# REQUIRED API KEYS
DATABASE_URL=your-database-url-here
GEMINI_API_KEY=your-gemini-api-key-here

# ===== OPTIONAL API KEYS + VARIABLES ===== #

# Core local app URLs
CLIENT_DOMAIN=http://localhost:3000
API_DOMAIN=http://localhost:8000
WEBHOOK_BASE_URL=http://localhost:8000
CELERY_API_URL=http://localhost:8001
CELERY_BROKER_URL=pyamqp://guest:guest@localhost:5672//

# Select the default provider used when a request does not specify one
LLM_DEFAULT_PROVIDER=gemini
LLM_CONFIG_PATH=./config/llm.yaml

# Optional multi-provider configuration
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_DEFAULT_MODEL=gpt-4.1
OPENAI_FAST_MODEL=gpt-4.1-mini

GROQ_API_KEY=your-groq-api-key-here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_DEFAULT_MODEL=openai/gpt-oss-120b
GROQ_FAST_MODEL=moonshotai/kimi-k2-instruct-0905

CEREBRAS_API_KEY=your-cerebras-api-key-here
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_DEFAULT_MODEL=gpt-oss-120b
CEREBRAS_FAST_MODEL=zai-glm-4.7

# Example custom OpenAI-compatible provider secret.
# Define the provider itself in config/llm.yaml and reference this env var there.
FUSE_API_KEY=your-fuse-api-key-here

# Required for server/app/database/telemetry.py if you want to enable PostHog telemetry for data collection and analysis
POSTHOG_API_KEY=your-posthog-api-key-here
POSTHOG_HOST=your-posthog-host-here

# Required for server/app/llm/speech.py if you want to use the audio feature
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint-here

# Required for using the explore search mode in the discover pipeline
EXA_API_KEY=your-exa-api-key-here
