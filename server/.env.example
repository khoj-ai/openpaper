# REQUIRED API KEYS
DATABASE_URL=your-database-url-here
GEMINI_API_KEY=your-gemini-api-key-here

# ===== OPTIONAL API KEYS + VARIABLES ===== #

# Required for server/app/database/telemetry.py if you want to enable PostHog telemetry for data collection and analysis
POSTHOG_API_KEY=your-posthog-api-key-here
POSTHOG_HOST=your-posthog-host-here

# Required for server/app/llm/speech.py if you want to use the audio feature
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=your-azure-openai-endpoint-here

# Required for using the explore search mode in the discover pipeline
EXA_API_KEY=your-exa-api-key-here

# Optional: authenticated OpenAlex API access (higher rate limits, fewer timeouts)
OPENALEX_API_KEY=your-openalex-api-key-here

# Zotero OAuth (account connect for library API access)
ZOTERO_CLIENT_KEY=your-zotero-client-key-here
ZOTERO_CLIENT_SECRET=your-zotero-client-secret-here
ZOTERO_REDIRECT_URI=http://localhost:8000/api/auth/zotero/callback

# PDF processing (uploads and Zotero import). Must match the jobs service broker.
CELERY_BROKER_URL=pyamqp://guest@localhost:5672//
CELERY_API_URL=http://localhost:8001
